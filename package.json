{
  "name": "playguard",
  "version": "0.2.1",
  "description": "MCP proxy for Playwright and Figma — token optimization, auto session recovery, and unified routing",
  "keywords": ["mcp", "playwright", "figma", "ai-agent", "claude", "browser-automation"],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "type": "module",
  "scripts": {
