    "analyze": "node bench/analyze.mjs",
    "test": "tsc && node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@playwright/mcp": "0.0.76",
    "js-yaml": "^5.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
